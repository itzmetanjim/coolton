# --- AI provider keys ---------------------------------------------------------
# At least ONE provider key is required. coolton tries providers in the fallback
# order defined in agent/agent.py (_build_provider_order), using the FIRST keyed
# provider, then falling through on failure. You do NOT need to set all of them.
#
# Effective order (first key present wins):
#   JAMS_API_KEY  -> JAMS (Kimi / MiniMax / etc.)
#   HCAI_API_KEY  -> HCAI gateway
#   OPENROUTER_API_KEY / OPENROUTER_API_KEY_FALLBACK -> OpenRouter
#   ANTHROPIC_API_KEY -> Anthropic
#   OPENAI_API_KEY    -> OpenAI
#   GROQ_API_KEY      -> Groq
#   GOOGLE_API_KEY    -> Gemini
#   MISTRAL_API_KEY   -> Mistral
#   CEREBRAS_API_KEY  -> Cerebras
JAMS_API_KEY=YOUR_JAMS_API_KEY
HCAI_API_KEY=YOUR_HCAI_API_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_API_KEY_FALLBACK=YOUR_OPENROUTER_API_KEY_FALLBACK
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY

# Optional, uncomment and set when running without the Slack CLI (python3 app.py).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Required for OAuth (app_oauth.py). Set your app's OAuth credentials.
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL

# Web search via Exa (free tier available)
# EXA_API_KEY=YOUR_EXA_API_KEY

# E2B sandbox for code execution
# E2B_API_KEY=YOUR_E2B_API_KEY

# AgentMail — email inbox API for AI agents (https://agentmail.to)
# Get a key at https://console.agentmail.to
# AGENTMAIL_API_KEY=am_us_YOUR_AGENTMAIL_KEY

# BYOK encryption key (auto-generated if not set, saved to byok_key.bin)
# BYOK_ENCRYPTION_KEY=YOUR_CUSTOM_ENCRYPTION_KEY

# Optional: Cooldown User for MCP-enabled API calls
# COOLTON_USER_ID=U12345678
# SLACK_USER_TOKEN=xoxp-...
