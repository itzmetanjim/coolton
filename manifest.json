{
  "display_information": {
    "name": "coolton (UNSTABLE BETA)",
    "description": "coolton is a much cooler cooler ai than gorkie, this one is prod",
    "background_color": "#083927"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "assistant_view": {
      "assistant_description": "cool cool coool ai cooler than gorkie, made by tanjim"
    },
    "bot_user": {
      "display_name": "coolton",
      "always_online": true
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://ngrok-free.app/slack/oauth_redirect"
    ],
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "channels:write.invites",
        "groups:write",
        "reactions:write",
        "reactions:read",
        "users:read",
        "assistant:write"
      ],
      "user": [
        "search:read",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "mpim:history",
        "users:read",
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "channels:write",
        "groups:write",
        "canvases:read",
        "canvases:write",
        "users:read.email"
      ]
    }
  },
  "settings": {
    "socket_mode_enabled": true,
    "org_deploy_enabled": true,
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://ngrok-free.app/slack/events"
    },
    "event_subscriptions": {
      "request_url": "https://ngrok-free.app/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "assistant_thread_started",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "token_rotation_enabled": false,
    "is_mcp_enabled": true
  }
}
